{
  "name": "mrl-media",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:api": "tsx watch src/api/server.ts",
    "dev:worker": "tsx watch src/worker/index.ts",
    "test": "vitest run",
    "test:slow": "node scripts/matrix-slow.mjs",
    "test:watch": "vitest",
    "lint:ts": "tsc --noEmit",
    "auth:generate": "better-auth generate --config src/auth.ts --output src/db/schema/auth.ts --yes",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "scale:local": "node scripts/local-scale.mjs",
    "scale:artillery": "artillery run scripts/artillery-local.yml",
    "scale:compose": "node scripts/compose-scale.mjs",
    "redis:cluster": "node scripts/redis-cluster.mjs",
    "redis:cluster:smoke": "tsx scripts/redis-cluster-smoke.ts",
    "redis:cluster:down": "node scripts/redis-cluster.mjs --down",
    "chaos": "node scripts/chaos.mjs",
    "e2e:video": "node scripts/e2e-video.mjs",
    "e2e:anonymous": "node scripts/e2e-anonymous.mjs",
    "infra:up": "docker compose up -d redis postgres",
    "redis:up": "docker compose up -d redis",
    "redis:down": "docker compose down"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1079.0",
    "@better-auth/api-key": "^1.6.23",
    "@better-auth/core": "1.6.23",
    "@better-auth/utils": "0.4.2",
    "@fastify/multipart": "^10.0.0",
    "better-auth": "^1.6.23",
    "better-call": "1.3.7",
    "bullmq": "^5.79.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.9.0",
    "ioredis": "^5.11.1",
    "pg": "^8.22.0",
    "prom-client": "^15.1.3",
    "sharp": "^0.35.2"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@types/node": "^26.0.1",
    "@types/pg": "^8.20.0",
    "artillery": "^2.0.33",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
